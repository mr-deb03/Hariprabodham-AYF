# Copy to .env and fill in. Never commit the real .env or the service-account JSON.

# --- Google Drive ---
# ID of the Drive folder holding your event photos (the long string in the folder URL).
DRIVE_FOLDER_ID=your_drive_folder_id_here
# Path to the service-account key JSON (download from Google Cloud Console).
GOOGLE_CREDENTIALS_FILE=service-account.json

# --- Face matching (DeepFace) ---
FACE_MODEL=ArcFace
FACE_DETECTOR=retinaface
# 0 = use the model's default distance threshold. Lower = stricter matching.
MATCH_THRESHOLD=0

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio sandbox sender; replace with your approved WhatsApp number in production.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- App ---
# Must be a PUBLIC URL Twilio can reach to fetch matched images.
# For local dev, expose port 8000 with ngrok and paste the https URL here.
PUBLIC_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
ALBUM_CACHE_DIR=album_cache
MAX_PHOTOS_TO_SEND=10
