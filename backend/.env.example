# Copy to .env for local dev. Never commit the real .env or service-account JSON.

# --- Google Drive ---
DRIVE_FOLDER_ID=your_drive_folder_id_here
# LOCAL dev: point to the downloaded key file.
GOOGLE_CREDENTIALS_FILE=service-account.json
# MANAGED hosting: paste the FULL service-account JSON as one line instead
# (leave GOOGLE_CREDENTIALS_FILE unused). Takes precedence when set.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ...}

# --- Face matching (InsightFace) ---
FACE_MODEL_PACK=buffalo_l        # or buffalo_s for smaller/lighter instances
MATCH_THRESHOLD=0.35             # 0.30 = looser, 0.45 = stricter

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Telegram (Bot API) — free, official, no ban risk ---
# Token from @BotFather. When set, the bot auto-registers its webhook on
# startup. The website form returns a t.me/<bot>?start=<token> link; the
# visitor opens it and presses Start to receive their matched photos.
TELEGRAM_BOT_TOKEN=
# Optional: any random string; Telegram echoes it back so we can verify calls.
TELEGRAM_WEBHOOK_SECRET=
# Optional: bot @username (without @) for the deep link. Auto-detected via
# getMe when left blank — only set it to skip that lookup.
TELEGRAM_BOT_USERNAME=
# Override the Telegram API host if your server can't reach api.telegram.org
# directly (e.g. some HF Spaces). Point it at a proxy — see
# telegram-proxy-worker.js. Leave default otherwise.
TELEGRAM_API_BASE=https://api.telegram.org

# --- App ---
# Public URL Twilio fetches matched images from. Auto-detected on Hugging Face
# Spaces (SPACE_HOST) and Render; for local testing use an ngrok https URL.
PUBLIC_BASE_URL=http://localhost:8000
# Allowed browser origins (your Vercel site + local dev).
CORS_ORIGINS=http://localhost:3000,https://your-site.vercel.app
ALBUM_CACHE_DIR=album_cache
MAX_PHOTOS_TO_SEND=10
