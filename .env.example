# Frontend environment variables (Create React App reads REACT_APP_* at build/start).
# Copy to .env.local for local dev, and set the same keys in Vercel → Settings →
# Environment Variables for production. Restart `npm start` after editing.

# Smruti face-match backend (Hugging Face Space)
REACT_APP_SMRUTI_ENDPOINT=https://your-space.hf.space/api/smruti

# Karyakarta Portal — Supabase (Project Settings → API). Publishable key is client-safe.
REACT_APP_SUPABASE_URL=https://xxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sb_publishable_xxx

# YouTube auto-sync (YouTube Data API v3 key, restrict it by HTTP referrer to your domain)
REACT_APP_YT_API_KEY=
# Channel id (UC…) or @handle — drives the public videos shown in the Media section
REACT_APP_YT_CHANNEL_ID=
# Unlisted "Karyakarta" playlist id — drives the gated Satsang Videos in the portal
REACT_APP_YT_MEMBER_PLAYLIST=
